{
  "name": "cursus",
  "version": "2.243.2",
  "description": "Cursus - Suivez votre parcours de formation",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:check": "vue-tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build:check && electron-builder --win --publish never",
    "build:win:ci": "npm run build && electron-builder --win --publish never",
    "build:mac": "npm run build:check && electron-builder --mac",
    "build:mac:ci": "npm run build && electron-builder --mac",
    "build:linux": "npm run build:check && electron-builder --linux",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --fix",
    "check:design": "node scripts/check-design-tokens.js",
    "check:design:snapshot": "node scripts/check-design-tokens.js --snapshot",
    "check:design:full": "node scripts/check-design-tokens.js --full",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "node scripts/postinstall.js",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "server:pm2": "pm2 start config/ecosystem.config.js --env production",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "vite build --config vite.web.config.ts --mode production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:frontend": "vitest run --project frontend",
    "test:backend": "npm rebuild better-sqlite3 && vitest run --project backend",
    "test:ci": "npm rebuild better-sqlite3 && vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "keywords": [
    "electron",
    "vue",
    "education",
    "cursus"
  ],
  "author": "Rohan Fossé",
  "license": "MIT",
  "dependencies": {
    "@azure/msal-node": "^5.1.2",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@hocuspocus/provider": "^3.4.4",
    "@hocuspocus/server": "^3.4.4",
    "@marp-team/marp-core": "^4.3.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@octokit/rest": "^22.0.1",
    "@tiptap/extension-collaboration": "^3.22.3",
    "@tiptap/extension-collaboration-caret": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/vue-3": "^3.22.3",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "codemirror": "^6.0.2",
    "cors": "^2.8.6",
    "dompurify": "^3.4.1",
    "dotenv": "^17.3.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "katex": "^0.16.45",
    "lucide-vue-next": "0.577.0",
    "mammoth": "^1.12.0",
    "marked": "^17.0.5",
    "mermaid": "^11.14.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "open-graph-scraper": "^6.11.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "pinia": "^2.3.1",
    "pyodide": "^0.29.3",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0",
    "vue": "^3.5.30",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.6.4",
    "y-prosemirror": "^1.3.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.12"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "path-to-regexp": ">=0.1.13"
  },
  "build": {
    "appId": "dev.rohanfosse.cursus",
    "productName": "Cursus",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**"
    ],
    "files": [
      "out/**/*",
      "resources/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/bcryptjs/**/*",
      "!**/*.pdb",
      "!**/*.map",
      "!**/*.ts",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,LICENSE,license,History.md}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples,.github}",
      "!**/node_modules/.cache"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico",
      "artifactName": "Cursus-${version}-win.${ext}",
      "signAndEditExecutable": true,
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "rfc3161TimeStampServer": "http://timestamp.digicert.com"
      }
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns",
      "artifactName": "Cursus-${version}-mac.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png",
      "artifactName": "Cursus-${version}-linux.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "rohanfosse",
      "repo": "cursus"
    },
    "compression": "normal",
    "nsis": {
      "oneClick": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "language": "1036",
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cursus",
      "menuCategory": "Cursus",
      "deleteAppDataOnUninstall": false,
      "perMachine": false,
      "differentialPackage": true,
      "artifactName": "Cursus-Setup-${version}.${ext}",
      "uninstallDisplayName": "Cursus ${version}",
      "unicode": true
    }
  }
}
