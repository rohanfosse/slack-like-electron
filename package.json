{
  "name": "ceslack",
  "version": "2.0.0",
  "description": "CeSlack — Le Slack des promos CESI",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "vue-tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue --fix",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [
    "electron",
    "vue",
    "education",
    "cesi"
  ],
  "author": "Rohan Fossé <rohan.fosse@cesi.fr>",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "lucide-vue-next": "^0.577.0",
    "mammoth": "^1.12.0",
    "pinia": "^2.3.1",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^3.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vue-tsc": "^2.2.12"
  },
  "build": {
    "appId": "fr.cesi.ceslack",
    "productName": "CeSlack",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/.cache",
      "renderer/assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "renderer/assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "renderer/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "renderer/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
