{
  "name": "cursus",
  "version": "2.0.0",
  "description": "Cursus — Suivez votre parcours de formation",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "vue-tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue --fix",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "node scripts/postinstall.js",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "server:pm2": "pm2 start ecosystem.config.js --env production",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "vite build --config vite.web.config.ts --mode production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "electron",
    "vue",
    "education",
    "cursus"
  ],
  "author": "Rohan Fossé",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.6",
    "dompurify": "^3.3.3",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "highlight.js": "^11.11.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-vue-next": "^0.577.0",
    "mammoth": "^1.12.0",
    "marked": "^17.0.4",
    "multer": "^2.1.1",
    "pinia": "^2.3.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^3.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.0",
    "vue-tsc": "^2.2.12"
  },
  "build": {
    "appId": "dev.rohanfosse.cursus",
    "productName": "Cursus",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**"
    ],
    "files": [
      "out/**/*",
      "resources/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/bcryptjs/**/*",
      "!**/*.pdb",
      "!**/*.map",
      "!**/*.ts",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,LICENSE,license,History.md}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples,.github}",
      "!**/node_modules/.cache"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    },
    "compression": "maximum",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": "resources/installer-sidebar.bmp",
      "installerHeader": "resources/installer-header.bmp",
      "installerHeaderIcon": "resources/icon.ico",
      "language": "1036",
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cursus",
      "menuCategory": "Cursus",
      "deleteAppDataOnUninstall": false,
      "perMachine": false
    }
  }
}
