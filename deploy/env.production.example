# ── Cursus - Configuration Production ────────────────────────────────────────
# Copier ce fichier en .env sur le serveur et remplir les valeurs

# URL publique du serveur (utilisée par le frontend pour les appels API)
VITE_SERVER_URL=https://cursus.school

# Secret JWT (OBLIGATOIRE en production, min 32 caractères)
# Générer avec : openssl rand -base64 48
JWT_SECRET=

# Origines CORS autorisées
CORS_ORIGIN=https://cursus.school

# Port interne du serveur (ne pas changer sauf si conflit)
PORT=3001

# Chemins des données (volumes Docker)
DB_PATH=/data/db/cesi-classroom.db
UPLOAD_DIR=/data/uploads
